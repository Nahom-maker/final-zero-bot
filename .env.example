# ─── Server ─────────────────────────
PORT=3000

# ─── NVIDIA AI ───────────────────────
NVIDIA_API_KEY=your_nvidia_api_key_here
FAST_MODEL=meta/llama-3.1-8b-instruct
THINKER_MODEL=nvidia/llama-3.1-nemotron-super-49b-v1

# ─── Supabase ────────────────────────
